# config/Openbravo.properties is regenerated by gradlew setup inside the image
# (local copy has localhost:5432 hardcoded — excluding it avoids baking stale config)
config/Openbravo.properties

# Git and IDE
.git
.idea
*.iml

# Build output
build/
.gradle/

# NOTE: gradle.properties is intentionally NOT excluded.
# gradlew setup requires it to authenticate against Nexus/GitHub Packages.
# The bbdd credentials it contains are overwritten at runtime by migrate.sh
# via environment variables injected from AWS Secrets Manager.
