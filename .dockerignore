# config/Openbravo.properties is regenerated by gradlew setup inside the image
# (local copy has localhost:5432 hardcoded — excluding it avoids baking stale config)
config/Openbravo.properties

# Git and IDE
.git
.idea
*.iml

# Build output
build/
.gradle/

# gradle.properties contains Nexus/GitHub auth tokens — excluded from build context.
# Passed to the build as a Docker build secret (--secret id=gradle_props)
# so it is available only during the RUN step that needs it, never in image layers.
gradle.properties
